                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "403": {
                        "description": "无权限（holder不匹配）",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/sys_distributed_lock/renew": {
            "post": {
                "description": "为锁延长TTL，必须验证 lock_holder 是否匹配",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "分布式锁"
                ],
                "summary": "续期分布式锁",
                "parameters": [
                    {
                        "description": "续期参数",
                        "name": "data",
                        "in": "body",
                        "required": true,
