{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Example Swagger setup for Golang Gin.",
        "title": "Assistant API",
        "contact": {},
        "version": "1.0"
    },
    "host": "127.0.0.1:9876",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "检查服务健康状态，包括数据库和分布式锁",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "健康检查"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务不健康",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/sys_distributed_lock/acquire": {
            "post": {
                "description": "原子操作：如果锁不存在或已过期则获取成功",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "分布式锁"
                ],
                "summary": "尝试获取分布式锁",
                "parameters": [
                    {
                        "description": "锁参数",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_app_modules_sys_distributed_lock.acquireReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/sys_distributed_lock/check/{lock_key}": {
            "get": {
                "description": "返回锁是否被持有（未过期）以及holder",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "分布式锁"
                ],
                "summary": "检查锁是否被持有",
                "parameters": [
                    {
                        "type": "string",
                        "description": "锁Key",
                        "name": "lock_key",
                        "in": "path",
                        "required": true
