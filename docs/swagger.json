                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/sys_distributed_lock/release": {
            "post": {
                "description": "释放锁，必须提供 lock_holder 验证所有权",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "分布式锁"
                ],
                "summary": "释放分布式锁",
                "parameters": [
                    {
                        "description": "释放参数",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_app_modules_sys_distributed_lock.releaseReq"
