                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/assistant_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/sys_distributed_lock/query/{lock_key}": {
            "get": {
                "description": "获取锁的详细信息（包含holder、TTL等）",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "分布式锁"
                ],
                "summary": "查询锁信息",
                "parameters": [
                    {
                        "type": "string",
